# TERRA-STATE: VOX ATLAS — Environment Variables
# Copy this file to terra-state/.env and fill in your values.
# All integrations fall back to mock mode if a key is unset — the app runs fine without any keys.

# ── Auth0 (M2M Agent Authentication) ─────────────────────────────────────────
# Required for live JWT validation on POST /agent-request
# Without these, use Bearer token "dev-token" in the Agent Console
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://terra-state.api
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ── Google Gemini (AI Planetary Advisor) ──────────────────────────────────────
# Required for live Gemini analysis on GET /analyze
# Without this, the advisor returns deterministic mock alerts
GEMINI_API_KEY=AIzaSy...

# ── Snowflake (Telemetry Sink) ────────────────────────────────────────────────
# Required for live tick logging to TERRA_WORLD_TICKS table
# Without these, tick data is logged to console only
SNOWFLAKE_ACCOUNT=account.region.snowflakecomputing.com
SNOWFLAKE_USER=TERRA_USER
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=TERRA_STATE
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# ── Backboard (Remote Config) ─────────────────────────────────────────────────
# Required for live climate multiplier overrides (drought_severity_index, global_market_demand)
# Without this, multipliers default to 1.0 (neutral)
BACKBOARD_API_KEY=bb_live_...
