# ─────────────────────────────────────────────────────────────────────────────
# TERRA-STATE Environment Variables
# Copy this file to .env and fill in your real credentials.
# NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth0 ────────────────────────────────────────────────────────────────────
# Your Auth0 tenant domain (no https://)
AUTH0_DOMAIN=your-tenant.us.auth0.com

# The API Audience identifier you registered in Auth0 Dashboard → Applications → APIs
AUTH0_AUDIENCE=https://terra-state-api

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Snowflake ─────────────────────────────────────────────────────────────────
# Account identifier: <org>-<account_name> (e.g. myorg-myaccount)
SNOWFLAKE_ACCOUNT=your_account.us-east-1
SNOWFLAKE_USER=terra_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_DATABASE=TERRA_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=TERRA_WH

# ── Backboard ─────────────────────────────────────────────────────────────────
BACKBOARD_API_KEY=your_backboard_api_key_here
